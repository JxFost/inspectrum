# Google Calendar service account credentials.
# See SCHEDULER_SETUP.md for how to get these.

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# Resend email — see EMAIL_SETUP.md for details.
RESEND_API_KEY=re_...
EMAIL_FROM="Inspectrum Inspections <office@evergreeninspections.com>"
PUBLIC_SITE_URL=https://evergreeninspections.com

# Google Analytics — optional, only loads when set.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Additional calendars to check for conflicts (comma-separated, optional).
GOOGLE_BUSY_CALENDAR_IDS=harry@evergreeninspections.com

# Admin panel — single shared password, no user accounts.
ADMIN_PASSWORD=changeme
# Session cookie signing key. Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=your-secret-here

# ACC inbound email webhook — secret for CloudMailin verification.
# Add as ?secret=<value> to the CloudMailin target URL.
INBOUND_WEBHOOK_SECRET=your-webhook-secret
